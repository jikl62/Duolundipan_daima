    {
        memcpy(pDst, pSrc, blockSize*sizeof(float32_t) );
        pA = pDst;
    }
    else
        pA = pSrc;


    for (i = blockSize/2 - 1; i >= 0; i--)
        arm_heapify(pA, blockSize, i, S->dir);

    for (i = blockSize - 1; i >= 0; i--)
    {

 temp = pA[i];
 pA[i] = pA[0];
        pA[0] = temp;


 arm_heapify(pA, i, 0, S->dir);
    }
}
