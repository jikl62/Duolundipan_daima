            do
            {
                i++;
            } while (pSrc[i] < pivot && i<last);


            do
            {
                j--;
            } while (pSrc[j] > pivot);
        }
        else
        {

            do
            {
                i++;
            } while (pSrc[i] > pivot && i<last);


            do
            {
                j--;
            } while (pSrc[j] < pivot);
        }


        if (i < j)
        {

            temp=pSrc[i];
            pSrc[i]=pSrc[j];
            pSrc[j]=temp;
        }
    }

    return j;
