static void arm_heapify(float32_t * pSrc, uint32_t n, uint32_t i, uint8_t dir)
{

    uint32_t k = i;
    uint32_t l = 2*i + 1;
    uint32_t r = 2*i + 2;
    float32_t temp;

    if (l < n && dir==(pSrc[l] > pSrc[k]) )
        k = l;

    if (r < n && dir==(pSrc[r] > pSrc[k]) )
        k = r;

    if (k != i)
    {
 temp = pSrc[i];
 pSrc[i]=pSrc[k];
 pSrc[k]=temp;

        arm_heapify(pSrc, n, k, dir);
    }
}
